  "all_or_nothing": false,
  "empleados": [
    {
      "_row": 1,
      "curp": "GACJ850203HDFRZN07",
      "rfc": "GACJ850203AB1",
      "nss": "12345678902",
      "cp": "06600",
      "paterno": "García",
      "materno": "Cruz",
      "nombre": "José",
