  "curp": "PEGJ900101HDFRZN09",
  "rfc": "PEGJ900101AB1",
  "nss": "12345678901",
  "cp": "06600",
  "paterno": "Pérez",
  "materno": "García",
  "nombre": "Juan",
  "interbancaria": "012345678901234567",
  "turno": 5,
  "puesto": 1364,
  "periodicidad": 12,
